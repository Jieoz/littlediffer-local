# Little Differ — local Nginx/PHP edition example config.
#
# Serves the static-ish PHP entrypoint and vendored assets. PHP is only the
# template/entrypoint: all diffing happens in the browser, so PHP-FPM only ever
# renders index.php. No request body is processed, stored, or uploaded.
#
# Usage:
#   1. Adjust `root` to the absolute path of this repo's `public/` directory.
#   2. Adjust the fastcgi_pass socket/host to match your PHP-FPM install.
#   3. Reload nginx:  nginx -t && nginx -s reload

server {
    listen 8080;
    server_name localhost;

    # Point this at <repo>/public
    root /workspace/repos/littlediffer-local/public;
    index index.php;

    # Vendored fonts: long cache, immutable.
    location /vendor/ {
        access_log off;
        expires 30d;
        add_header Cache-Control "public, immutable";
        try_files $uri =404;
    }

    # Static assets (css/js). Versioned via ?v= query in index.php.
    location /assets/ {
        access_log off;
        expires 7d;
        add_header Cache-Control "public";
        try_files $uri =404;
    }

    location = /icon.png {
        access_log off;
        expires 30d;
        try_files $uri =404;
    }

    # Everything else is served by the PHP entrypoint.
    location / {
        try_files $uri /index.php$is_args$args;
    }

    location ~ \.php$ {
        include fastcgi_params;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;

        # Choose ONE of the following to match your environment:
        fastcgi_pass unix:/run/php/php-fpm.sock;
        # fastcgi_pass 127.0.0.1:9000;
    }

    # The app needs no server-side storage; deny dotfiles just in case.
    location ~ /\. { deny all; }
}
